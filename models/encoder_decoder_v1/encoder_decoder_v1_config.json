{
    "model_name": "encoder_decoder_v1",
    "framework": "Keras / TensorFlow",
    "input_shape": [
        256,
        256,
        3
    ],
    "output_channels": 1,
    "task": "binary image segmentation",
    "architecture": {
        "encoder_block_1": [
            "Conv2D(16,3x3)+ReLU",
            "Conv2D(16,3x3)+ReLU",
            "MaxPool"
        ],
        "encoder_block_2": [
            "Conv2D(32,3x3)+ReLU",
            "Conv2D(32,3x3)+ReLU",
            "MaxPool"
        ],
        "bottleneck": [
            "Conv2D(64,3x3)+ReLU",
            "Conv2D(64,3x3)+ReLU"
        ],
        "decoder_block_1": [
            "UpSampling",
            "Conv2D(32,3x3)+ReLU"
        ],
        "decoder_block_2": [
            "UpSampling",
            "Conv2D(16,3x3)+ReLU"
        ],
        "output": [
            "Conv2D(1,1x1)",
            "Sigmoid"
        ]
    },
    "optimizer": "Adam",
    "learning_rate": 0.001,
    "loss": "binary_crossentropy",
    "batch_size": 8,
    "epochs": 15,
    "prediction_threshold": 0.5
}