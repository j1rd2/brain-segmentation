{
    "model_name": "encoder_decoder_v4",
    "framework": "Keras / TensorFlow",
    "input_shape": [
        256,
        256,
        3
    ],
    "output_channels": 1,
    "task": "binary image segmentation",
    "architecture": {
        "type": "encoder_decoder_v4",
        "encoder_1": [
            "SeparableConv2D(3x3,8)+ReLU",
            "SeparableConv2D(3x3,8)+ReLU",
            "MaxPooling2D(2x2)"
        ],
        "encoder_2": [
            "SeparableConv2D(3x3,16)+ReLU",
            "SeparableConv2D(3x3,16)+ReLU",
            "MaxPooling2D(2x2)"
        ],
        "encoder_3": [
            "SeparableConv2D(3x3,32)+ReLU",
            "SeparableConv2D(3x3,32)+ReLU",
            "MaxPooling2D(2x2)"
        ],
        "bottleneck": [
            "SeparableConv2D(3x3,64)+ReLU",
            "SeparableConv2D(3x3,64)+ReLU"
        ],
        "decoder_1": [
            "UpSampling2D(2x2)",
            "Concat skip",
            "SeparableConv2D(3x3,32)+ReLU",
            "SeparableConv2D(3x3,32)+ReLU"
        ],
        "decoder_2": [
            "UpSampling2D(2x2)",
            "Concat skip",
            "SeparableConv2D(3x3,16)+ReLU",
            "SeparableConv2D(3x3,16)+ReLU"
        ],
        "decoder_3": [
            "UpSampling2D(2x2)",
            "Concat skip",
            "SeparableConv2D(3x3,8)+ReLU",
            "SeparableConv2D(3x3,8)+ReLU"
        ],
        "output": [
            "Conv2D(1x1,1)",
            "Sigmoid"
        ]
    },
    "optimizer": "Adam",
    "learning_rate": 0.001,
    "loss": "bce_dice_loss",
    "training_metric": "dice_coefficient",
    "batch_size": 8,
    "epochs": 15,
    "prediction_threshold": 0.5,
    "evaluation_thresholds": [
        0.5,
        0.6,
        0.7,
        0.75
    ],
    "callbacks": [
        "ModelCheckpoint",
        "ReduceLROnPlateau",
        "CSVLogger"
    ]
}